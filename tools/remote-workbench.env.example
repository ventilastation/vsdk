# Copy outside the repository, fill in real values, and load before starting:
#   python3 -m emulator.remote_gateway serve
# Never put this file's populated form in GitHub Pages or Git.

REMOTE_WORKBENCH_BOARD=workbench-1
REMOTE_WORKBENCH_TICKET_AUDIENCE=ventilastation-remote-workbench
REMOTE_WORKBENCH_TICKET_KEY_FILE=/Users/you/.config/vsdk/remote-workbench/ticket.key
REMOTE_WORKBENCH_STATE_DB=/Users/you/.local/state/vsdk/remote-workbench/state.sqlite3
REMOTE_WORKBENCH_HOST=ventilastation-workbench.local
REMOTE_WORKBENCH_PORT=5005
REMOTE_WORKBENCH_SERIAL_PORT=/dev/cu.usbmodemWORKBENCH
REMOTE_WORKBENCH_ALLOWED_ORIGINS=https://ventilastation.protocultura.net
REMOTE_WORKBENCH_BIND=127.0.0.1
REMOTE_WORKBENCH_BIND_PORT=8765

# The Cloudflare Access team domain and the Access application's AUD tag.
CF_ACCESS_TEAM_DOMAIN=your-team.cloudflareaccess.com
CF_ACCESS_AUDIENCE=replace-with-access-application-audience

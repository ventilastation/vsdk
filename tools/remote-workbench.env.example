# Copy outside the repository, fill in real values, and load before starting:
#   python3 -m emulator.remote_gateway serve
# Never put this file's populated form in GitHub Pages or Git.

export REMOTE_WORKBENCH_BOARD=workbench-1
export REMOTE_WORKBENCH_TICKET_AUDIENCE=ventilastation-remote-workbench
export REMOTE_WORKBENCH_TICKET_KEY_FILE=/Users/you/.config/vsdk/remote-workbench/ticket.key
export REMOTE_WORKBENCH_STATE_DB=/Users/you/.local/state/vsdk/remote-workbench/state.sqlite3
export REMOTE_WORKBENCH_HOST=ventilastation-workbench.local
export REMOTE_WORKBENCH_PORT=5005
export REMOTE_WORKBENCH_SERIAL_PORT=/dev/cu.usbmodemWORKBENCH
export REMOTE_WORKBENCH_ALLOWED_ORIGINS=https://ventilastation.protocultura.net
export REMOTE_WORKBENCH_BIND=127.0.0.1
export REMOTE_WORKBENCH_BIND_PORT=8765

# WebRTC media normally connects directly between the authenticated browser
# and this host. STUN is sufficient on most networks. Supply a JSON array with
# a TURN entry as well when either side is behind symmetric NAT/CGNAT. TURN
# credentials are sent only inside HELLO on the authenticated WebSocket.
export REMOTE_WORKBENCH_ICE_SERVERS_JSON='[{"urls":["stun:stun.l.google.com:19302"]}]'

# Production default: ngrok authenticates the request with Google OAuth,
# removes caller-supplied identity headers, then injects these values from the
# verified identity. Do not make the gateway reachable except through that
# loopback-only tunnel in this mode.
export REMOTE_WORKBENCH_AUTH_MODE=trusted-proxy
export REMOTE_WORKBENCH_TRUSTED_EMAIL_HEADER=X-Remote-Email
export REMOTE_WORKBENCH_TRUSTED_SUBJECT_HEADER=X-Remote-Subject

# Optional legacy Cloudflare Access mode. Set AUTH_MODE=cloudflare-access and
# fill both values only when using that provider instead of ngrok.
# export CF_ACCESS_TEAM_DOMAIN=your-team.cloudflareaccess.com
# export CF_ACCESS_AUDIENCE=replace-with-access-application-audience

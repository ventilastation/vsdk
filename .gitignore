# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.ruff_cache/

# Build output (ESP-IDF, MicroPython ports, packaging)
build/

# Local MicroPython checkout used for the ESP32 firmware build (see BUILDING.md)
hardware/rotor/micropython

# Generated artifacts
apps/micropython/roms/*.rom
*.mp3.wav

# Game packages pushed from the editor (see emulator/package_manager.py)
installed_packages/

# Per-device / per-user state
apps/micropython/ventilastation/settings.json

# Vendored-at-setup binaries (see emulator/ffmpeg-win/README.md)
emulator/ffmpeg-win/*.dll
emulator/ffmpeg-win/*.exe

# Built by emulator/native/build.sh (see native_render.py); platform-specific,
# rebuilt automatically by vs-emu.sh.
emulator/native/*.so
emulator/native/*.dll
emulator/native/*.dylib

# Node
node_modules/

# Editors and OS noise
.vscode/
.history/
*.code-workspace
.DS_Store
Thumbs.db
.*.swp
dist/*
apps/micropython/sencom.hi
